//	load_file("sstStimIndividualBranches.hoc")
//	load_file("sstStimAllBranches.hoc")
//	load_file("npyStimAllBranches.hoc")
}

// DO MAIN, REPEATED SIMULATIONS.
{
	load_file("iterateSims.hoc")
}

