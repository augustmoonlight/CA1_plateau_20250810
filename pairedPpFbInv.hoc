// This does paired PP-SC inputs with feedback from the tuft.

// Create graph.
objref ppFbInvGr
strdef lab1,lab2
lab1 = "I PP + FB"
lab2 = "Inh + exc + FB"
toRem = addTracesToGraph(ppFbInvGr,lab1,lab2)

// Prep synapses.
excInhPrep(nExcUseTuft,0,nInhFf,0,nInhFb,1)

// Run
run()

// Prep for next run.
graphList[0].remove(toRem-1)

