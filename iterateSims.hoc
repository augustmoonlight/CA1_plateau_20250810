// Visualise distributions.
objref somaVoltNoneHist,dend1VoltNoneHist,dend2VoltNoneHist
objref somaVoltVgatHist,dend1VoltVgatHist,dend2VoltVgatHist
objref somaVoltOtherHist,dend1VoltOtherHist,dend2VoltOtherHist
nBin = 50
//binWidth = (plotHi-plotLo)/nBin

if(plotHiSoma<0){ plotHiSoma = somaVoltNone.max*1.1 }
if(plotHiDend1<0){ plotHiDend1 = dend1VoltNone.max*1.1 }
if(plotHiDend2<0){ plotHiDend2 = dend2VoltNone.max*1.1 }

// Given two vectors, corresponding the x values desired in the histogram and
// and the observed values in the dataset, return EITHER the x axis ($3=0) or
// the y axis ($3=1) for the histogram.

// $o1: vector.  X values, defines the start and endpoints for bins.
// $o2: y values that are to be histogram'ed.
// $3: variable.  A switch to control whether the X or Y axis is returned
//	( $3 = 0: x axis ; $3 = 1: y axis)
obfunc getHistAxis(){local ii,loX,hiX,loY,hiY localobj sortY,binY,histX,histY,tempVec
	// Define local objects.
	tempVec = new Vector()
	binY = new Vector($o1.size()-1)  // subtract one as number of bins is one less than the number of X valus
	sortY = new Vector()

	
	// Populate histogram values.
	for ii=0,$o1.size()-2{
		loX = $o1.x[ii]
		hiX = $o1.x[ii+1]
		
	//	loY = sortY.indwhere("<",loX)
	//	hiY = sortY.indwhere("<",hiX)
	
		tempVec.indvwhere($o2,"[]",loX,hiX) // "[]" OK as working with floats
		binY.x[ii] = tempVec.size
		
	}
	
	// Manipulate X and Y axes to plot things as a nice cityscape view
	// in NEURON.
	histX = new Vector(3*(binY.size())+1)
	histY = new Vector(3*(binY.size())+1)
	
	histX.x[0] = $o1.x[0]
	histY.x[0] = 0
	
	for ii=0,binY.size()-1{	
		histX.x[3*ii+1] = $o1.x[ii]
		histX.x[3*ii+2] = $o1.x[ii+1]
		histX.x[3*ii+3] = $o1.x[ii+1]
	
		histY.x[3*ii+1] = binY.x[ii]
		histY.x[3*ii+2] = binY.x[ii]
		histY.x[3*ii+3] = 0
	}
	
	if($3<0.1){
		return histX
	}else{
		return histY
	}
}

objref somaVoltAxis,dend1VoltAxis,dend2VoltAxis
objref somaVoltHistX,dend1VoltHistX,dend2VoltHistX
objref somaVoltNoneHistY,dend1VoltNoneHistY,dend2VoltNoneHistY
objref somaVoltVgatHistY,dend1VoltVgatHistY,dend2VoltVgatHistY
objref somaVoltOtherHistY,dend1VoltOtherHistY,dend2VoltOtherHistY

objref somaVoltGr,dend1VoltGr,dend2VoltGr
somaVoltGr = new Graph()
dend1VoltGr = new Graph()
dend2VoltGr = new Graph()
somaVoltGr.label("Soma")
dend1VoltGr.label("Dend1")
dend2VoltGr.label("Dend2")

// Plot histograms.  Arguments allow the bins for the histograms to be switched,
// facilitating on-the-fly graphing.
// $1: variable.  low X value of histograms.
// $2: variable.  high X value of soma histogram.
// $3: variable.  high x value of dend1 histogram.
// $4: variable.  high x value of dend2 histogram.
// $5: optional variable.  Number of bins; defaults to nBin.
proc plotHist(){ local nb,pl,hs,hd1,hd2
	if(numarg()>4.1){
		nb = $5
	}else{
		nb = nBin
	}

	pl = $1
	hs = $2
	hd1 = $3
	hd2 = $4
	
	binWidthSoma = (hs-pl)/nb
	binWidthDend1 = (hd1-pl)/nb
	binWidthDend2 = (hd2-pl)/nb

	somaVoltAxis = new Vector(nb)
	dend1VoltAxis = new Vector(nb)
	dend2VoltAxis = new Vector(nb)
	somaVoltAxis.indgen(pl,binWidthSoma)
	dend1VoltAxis.indgen(pl,binWidthDend1)
	dend2VoltAxis.indgen(pl,binWidthDend2)

	somaVoltHistX = getHistAxis(somaVoltAxis,somaVoltNone,0)
	dend1VoltHistX = getHistAxis(dend1VoltAxis,dend1VoltNone,0)
	dend2VoltHistX = getHistAxis(dend2VoltAxis,dend2VoltNone,0)
	
	somaVoltNoneHistY = getHistAxis(somaVoltAxis,somaVoltNone,1)
	dend1VoltNoneHistY = getHistAxis(dend1VoltAxis,dend1VoltNone,1)
	dend2VoltNoneHistY = getHistAxis(dend2VoltAxis,dend2VoltNone,1)
	
	somaVoltVgatHistY = getHistAxis(somaVoltAxis,somaVoltVgat,1)
	dend1VoltVgatHistY = getHistAxis(dend1VoltAxis,dend1VoltVgat,1)
	dend2VoltVgatHistY = getHistAxis(dend2VoltAxis,dend2VoltVgat,1)
	
	somaVoltOtherHistY = getHistAxis(somaVoltAxis,somaVoltOther,1)
	dend1VoltOtherHistY = getHistAxis(dend1VoltAxis,dend1VoltOther,1)
	dend2VoltOtherHistY = getHistAxis(dend2VoltAxis,dend2VoltOther,1)


	somaVoltGr.erase()
	dend1VoltGr.erase()
	dend2VoltGr.erase()

	somaVoltNoneHistY.plot(somaVoltGr,somaVoltHistX,9,1)
	somaVoltVgatHistY.plot(somaVoltGr,somaVoltHistX,6,1)
	somaVoltOtherHistY.plot(somaVoltGr,somaVoltHistX,7,1)
	
	dend1VoltNoneHistY.plot(dend1VoltGr,dend1VoltHistX,9,1)
	dend1VoltVgatHistY.plot(dend1VoltGr,dend1VoltHistX,6,1)
	dend1VoltOtherHistY.plot(dend1VoltGr,dend1VoltHistX,7,1)
	
	dend2VoltNoneHistY.plot(dend2VoltGr,dend2VoltHistX,9,1)
	dend2VoltVgatHistY.plot(dend2VoltGr,dend2VoltHistX,6,1)
	dend2VoltOtherHistY.plot(dend2VoltGr,dend2VoltHistX,7,1)

	somaVoltGr.size(pl,hs,0,totSims)
	dend1VoltGr.size(pl,hd1,0,totSims)
	dend2VoltGr.size(pl,hd2,0,totSims)
	
	somaVoltGr.size(pl,hs,0,totSims)
	dend1VoltGr.size(pl,hd1,0,totSims)
	dend2VoltGr.size(pl,hd2,0,totSims)
	
	somaVoltGr.size(pl,hs,0,totSims)
	dend1VoltGr.size(pl,hd1,0,totSims)
	dend2VoltGr.size(pl,hd2,0,totSims)
}

plotHist(plotLo,plotHiSoma,plotHiDend1,plotHiDend2,nBin)
