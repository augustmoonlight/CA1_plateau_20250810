// Print output; how many spikes are above a certain voltage threshold?  This
// is done to address a question of Erik's in an email dated 4/23/15.
objref voltThresVec
{
	voltThresVec = new Vector()
	voltThresVec.indvwhere(dend2VoltNone,">=",voltThresReport)
	print "For no inhibition, number of events great than ",voltThresReport, " mV is ",voltThresVec.size()
	
	voltThresVec = new Vector()
	voltThresVec.indvwhere(dend2VoltVgat,">=",voltThresReport)
	print "For VGAT inhibition, number of events great than ",voltThresReport, " mV is ",voltThresVec.size()
	
	voltThresVec = new Vector()
	voltThresVec.indvwhere(dend2VoltOther,">=",voltThresReport)
	print "For non-VGAT inhibition, number of events great than ",voltThresReport, " mV is ",voltThresVec.size()
}
// Print output; how many spikes elicited somatic action potentials?  This
// is done to address a question of Erik's in an email dated 4/23/15.
voltThresReport = 60
{
	voltThresVec = new Vector()
	voltThresVec.indvwhere(somaVoltNone,">=",voltThresReport)
	print "For no inhibition, number of APs is ",voltThresVec.size()
	
	voltThresVec = new Vector()
	voltThresVec.indvwhere(somaVoltVgat,">=",voltThresReport)
	print "For VGAT inhibition, number of APs is ",voltThresVec.size()
	
	voltThresVec = new Vector()
	voltThresVec.indvwhere(somaVoltOther,">=",voltThresReport)
	print "For non-VGAT inhibition, number of APs is ",voltThresVec.size()
}



