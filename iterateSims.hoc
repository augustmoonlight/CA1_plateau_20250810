// ITERATE FOR A GIVEN SIMULATION TO UNDERSTAND THE ROBUSTNESS OF RESPONSES.
strdef genToTarget

// Run a few simulations, recording peak voltages everywhere, and plot results.
// Ensure that the genotype (e.g., "sst") and the domain (e.g., tuftList) are
// switched proeprly in the activateExcitation() and activateInhibition()
// calls.
totSims = 100 // number of simulations to run; if set = 1, do pilot
doTbs = 0 // spread out inputs in time like TBS?  [simultaneously vs. split across 5 stimuli at 10 msec intervals]
doTuft = 1 // switch to control between tuft simulations and SO/SR simulations


// Parameters that don't need to be varied.
tstop = 150+doTbs*50 // do 150 if not doing TBS, 200 otherwise
excStart = 100
inhStart = excStart
tbsInt = 10 // in msec, spacing between TBS epochs
tbsN = 5 // number of TBS epochs

if(doTuft){
	if(1==cellId){
		nExcAct = 100 // number of excitatory synapses to activate
		nInhAct = 20 // number of inhibitory synapses to activate; cant go higher than 87
	
		dendInd1 = 101 // left apical, just past SR/SLM border
		dendInd2 = 149 // left apical, terminal neurite
		
		plotHiSoma = -1
		plotHiDend1 = -1
		plotHiDend2 = -1
		if(abs(totSims-1)<0.1){
			randShift = 50 // shift the seed; used for toggling between sub and suprathreshold random instances
				      // used for getting representative traces for sup
				      // = 0 produces a subthreshold tuft 
		}else{
			randShift = 0
		}
	}else{
		print "***********************still need to tune inputs for Cell 2"
		nExcAct = 100 // number of excitatory synapses to activate
		nInhAct = 20 // number of inhibitory synapses to activate; cant go higher than 87
	
		dendInd1 = 105 // right apical, just past SR/SLM border
		dendInd2 = 131 // right apical, terminal neurite
		
		plotHiSoma = -1
		plotHiDend1 = -1
		plotHiDend2 = -1
		if(abs(totSims-1)<0.1){
			randShift = 0 // shift the seed; used for toggling between sub and suprathreshold random instances
				      // used for getting representative traces for sup
				      // = 0 produces a subthreshold tuft 
		}else{
			randShift = 0
		}
	}
}else{
	if(1==cellId){
		nExcAct = 140+150*doTbs // number of excitatory synapses to activate
		nInhAct = 40//+40*doTbs // number of inhibitory synapses to activate; cant go higher than 94
	
		thresSwitch = 0 // to be removed later
		
		dendInd1 = 144 // radial oblique proximal to soma
		dendInd2 = 123 // radial oblique distal to soma
		
		plotHiSoma = -1 // 15 for subthreshold only
		plotHiDend1 = -1 // 20 for subthreshold only
		plotHiDend2 = -1 // 12 for subthreshold only
		
		if(abs(totSims-1)<0.1){
			randShift = 4 //1 // shift the seed; used for toggling between sub and suprathreshold random instances
				      // used for getting representative traces for sup
				      // = 1: all suprathreshold
				      // = 2: exc only suprathreshold
				      // = 3: all subthres
		}else{
			randShift = 0
		}
	}else{
		print "***********************still need to tune inputs for Cell 2"
		nExcAct = 140+150*doTbs // number of excitatory synapses to activate
		nInhAct = 40//+40*doTbs // number of inhibitory synapses to activate; cant go higher than 94
	
		dendInd1 = 49 // radial oblique proximal to soma
		dendInd2 = 72 // radial oblique distal to soma
		
		plotHiSoma = -1 // 15 for subthreshold only
		plotHiDend1 = -1 // 20 for subthreshold only
		plotHiDend2 = -1 // 12 for subthreshold only
		
		if(abs(totSims-1)<0.1){
			randShift = 1 // shift the seed; used for toggling between sub and suprathreshold random instances
				      // used for getting representative traces for sup
				      // = 1 produces a subthres response in NPY only
				      // = 2 produces a subthres response in VGAT and NPY 
		}else{
			randShift = 0
		}
	}
		
}
	
// 051815: look at weird basal behaviour
/*
print "Looking at weird basaliness"
objref tempGr,tempBox
tempBox = new VBox()
tempBox.intercept(1)
tempGr = new Graph()
tempGr.addvar("Cell[0].dend[144].v(0.5)",1,1)
tempGr.addvar("Cell[0].dend[123].v(0.5)",2,1)
tempGr.addvar("soma.sec.v(0.5)",3,1)
tempGr.size(100,120,-70,0)
graphList[0].append(tempGr)
tempGr.exec_menu("Keep Lines")
tempBox.intercept(0)
tempBox.map("volts",300,100,500,500)
*/

// Determine number of segments to track.
totSegs = 0
forall { for (x,0) { totSegs +=1 } }

// Create a distance associated with every segment; take a convention that
// basals are <0.
objref segDist
segDist = new Vector(totSegs)
soma.sec {distance()}
curSeg = 0
forall {
	curSec = new SectionRef()
	if(sectionRefInList(curSec,basalList)){
		coFact=-1
	}else{
		coFact=1
	}
	for(x,0){
		segDist.x[curSeg] = coFact*distance(x)
		curSeg+=1
	}
}

// Track peak voltages.
objref peakVoltNone[totSims],peakVoltVgat[totSims],peakVoltOther[totSims]
for ii=0,totSims-1{
	peakVoltNone[ii] = new Vector(totSegs)
	peakVoltVgat[ii] = new Vector(totSegs)
	peakVoltOther[ii] = new Vector(totSegs)
}





// Track baseline voltages to be subtracted.
objref baseVolts
baseVolts = new Vector(totSegs)

// Track distributions of a few special regions.
objref dend1Ref,dend2Ref
Cell[0].dend[dendInd1] {dend1Ref = new SectionRef()} 
Cell[0].dend[dendInd2] {dend2Ref = new SectionRef()} 
objref somaVoltNone,dend1VoltNone,dend2VoltNone
objref somaVoltVgat,dend1VoltVgat,dend2VoltVgat,somaVoltOther,dend1VoltOther,dend2VoltOther
somaVoltNone = new Vector(totSims)
dend1VoltNone = new Vector(totSims)
dend2VoltNone = new Vector(totSims)
somaVoltVgat = new Vector(totSims)
dend1VoltVgat = new Vector(totSims)
dend2VoltVgat = new Vector(totSims)
somaVoltOther = new Vector(totSims)
dend1VoltOther = new Vector(totSims)
dend2VoltOther = new Vector(totSims)

// Plot things, if only doing a pilot simulation.
objref voltGrNone,voltGrVgat,voltGrOther
objref shapeGrNone,shapeGrVgat,shapeGrOther
if(totSims<1.1){
	voltGrNone = new Graph()
	voltGrNone.addvar("soma.sec.v(0.5)",2,1)
	voltGrNone.addvar("dend1Ref.sec.v(0.5)",3,1) 
	voltGrNone.addvar("dend2Ref.sec.v(0.5)",4,1) 
	voltGrNone.label("No inhib, example volts")
	voltGrNone.exec_menu("Keep Lines")
	voltGrNone.size(90,150,-80,40)
	
	voltGrVgat = new Graph()
	voltGrVgat.addvar("soma.sec.v(0.5)",2,1)
	voltGrVgat.addvar("dend1Ref.sec.v(0.5)",3,1) 
	voltGrVgat.addvar("dend2Ref.sec.v(0.5)",4,1)  
	voltGrVgat.label("VGAT, example volts")
	voltGrVgat.exec_menu("Keep Lines")
	voltGrVgat.size(90,150,-80,40)
	
	voltGrOther = new Graph()
	voltGrOther.addvar("soma.sec.v(0.5)",2,1)
	voltGrOther.addvar("dend1Ref.sec.v(0.5)",3,1) 
	voltGrOther.addvar("dend2Ref.sec.v(0.5)",4,1)  
	voltGrOther.label("Other, example volts")
	voltGrNone.exec_menu("Keep Lines")
	voltGrOther.size(90,150,-80,40)
	
	shapeGrNone = new Shape()
	shapeGrNone.label("Exc")
	shapeGrVgat = new Shape()
	shapeGrVgat.label("VGAT")
	shapeGrOther = new Shape()
	shapeGrOther.label("Other")
}


// Run iterations of simulations.
objref curInh,curExc

// delete this later, used for storing number of on-path synapses
print "delete this object and associated references later"
objref onDend2
onDend2 = new Vector(totSims)

for iii=0,totSims-1 {
	print "************************* SIM#",iii
	// Call the below two functions only once per iteration, in order
	// to keep the channel properties and flagged genotypes constant
	// between simulations.
	initChannels()
	seedGenotypes() // re-distribute the flagged synapses
	
	// IF DOING THE VERY FIRST SIMULATIONS, CALCULATE BASELINE VOLTAGES
	// FOR LATER SUBTRACTION.
	if(iii<0.1){
		// Clear excitation and inhibition.
		activateExcitation(cellList,-1,iii+randShift) // shut off excitation
		activateInhibition(cellList,-1,iii+randShift) // shut off inhibition
		
		run()
		
		// Assign baseline voltages.
		curSeg = 0
		forall {
			for (x,0) {
				baseVolts.x[curSeg] = vm_vmax(x)
				curSeg+=1
			}
		}
		
		soma.sec { somaVoltBase = vm_vmax(0.5) }
		dend1Ref.sec { dend1VoltBase = vm_vmax(0.5) }
		dend2Ref.sec { dend2VoltBase = vm_vmax(0.5) }
	}
	
	// DO SIMULATIONS WITH NO INHIBITION AND STORE RESULTS.
		// Clear excitation and inhibition, and then turn on select synapses.
		activateExcitation(cellList,-1,iii+randShift) // shut off excitation
		activateInhibition(cellList,-1,iii+randShift) // shut off inhibition
		
		if(doTuft){
			curExc = activateExcitation(tuftList,nExcAct,iii+randShift)
		}else{
			curExc = activateExcitation(ca3List,nExcAct,iii+randShift)
		}
		
		for ii=0,curExc.size()-1{
			nsAmpa[curExc.x[ii]].start = excStart + doTbs*int( ii*tbsN/nExcAct + 0.0001)*tbsInt
			nsNmda[curExc.x[ii]].start = excStart + doTbs*int( ii*tbsN/nExcAct + 0.0001)*tbsInt
			if(totSims<1.1){	
				shapeGrNone.point_mark(synAmpa[curExc.x[ii]],2,"O",6)
			}
		}
		
		if(totSims<1.1){ 
			curGr = graphList[0].append(voltGrNone) 
		}
		
		run()
		
		// Assign peak voltages.
		curSeg = 0
		forall {
			for (x,0) {
				peakVoltNone[iii].x[curSeg] = vm_vmax(x)
				curSeg+=1
			}
		}
		
		// Assign specific distributions.
		soma.sec { somaVoltNone.x[iii] = vm_vmax(0.5) }
		dend1Ref.sec { dend1VoltNone.x[iii] = vm_vmax(0.5) }
		dend2Ref.sec { dend2VoltNone.x[iii] = vm_vmax(0.5) } 
		
	// DO VGAT SIMULATION AND STORE RESULTS.
		// Clear excitation and inhibition, and then turn on select synapses.
		activateExcitation(cellList,-1,iii+randShift) // shut off excitation
		activateInhibition(cellList,-1,iii+randShift) // shut off inhibition
		if(doTuft){
			curExc = activateExcitation(tuftList,nExcAct,iii+randShift)
			curInh = activateInhibition(tuftList,nInhAct,iii+randShift,"vgat",1,"sst",0)
		}else{
			curExc = activateExcitation(ca3List,nExcAct,iii+randShift)
			curInh = activateInhibition(ca3List,nInhAct,iii+randShift,"vgat",1,"npy",0)
		}
			
		
		
		for ii=0,curExc.size()-1{
			nsAmpa[curExc.x[ii]].start = excStart + doTbs*int( ii*tbsN/nExcAct + 0.0001)*tbsInt
			nsNmda[curExc.x[ii]].start = excStart + doTbs*int( ii*tbsN/nExcAct + 0.0001)*tbsInt
		}
		for ii=0,curInh.size()-1{
			nsVgatAt[curInh.x[ii]].start = inhStart + doTbs*int( ii*tbsN/nInhAct + 0.0001)*tbsInt
			if(totSims<1.1){
				shapeGrVgat.point_mark(synVgatAt[curInh.x[ii]],3,"O",6)
			}
		}
		
		if(totSims<1.1){ 
			graphList[0].remove(curGr-1)
			curGr = graphList[0].append(voltGrVgat) 
		}
		
		run()
		
		// Assign peak voltages.
		curSeg = 0
		forall {
			for (x,0) {
				peakVoltVgat[iii].x[curSeg] = vm_vmax(x)
				curSeg+=1
			}
		}
		
		// Assign specific distributions.
		soma.sec { somaVoltVgat.x[iii] = vm_vmax(0.5) }
		dend1Ref.sec { dend1VoltVgat.x[iii] = vm_vmax(0.5) }
		dend2Ref.sec { dend2VoltVgat.x[iii] = vm_vmax(0.5) } 
	// DO "OTHER" SIMULATION AND STORE RESULTS.
		// Clear excitation and inhibition, and then turn on select synapses.
		activateExcitation(cellList,-1,iii+randShift) // shut off excitation
		activateInhibition(cellList,-1,iii+randShift) // shut off inhibition
		if(doTuft){
			curExc = activateExcitation(tuftList,nExcAct,iii+randShift)
			curInh = activateInhibition(tuftList,nInhAct,iii+randShift,"vgat",1,"sst",1)		
		}else{
			curExc = activateExcitation(ca3List,nExcAct,iii+randShift)
			curInh = activateInhibition(ca3List,nInhAct,iii+randShift,"vgat",1,"npy",1)
		}
		
		// added this in; delete later
		print "deleter this later, using it to identify where synapses are loacted"
		numOn = 0
		numOff = 0
		for ii=0,curInh.size()-1{
			synVgatAt[curInh.x[ii]].get_loc(){
				print secname()
				if(abs(strcmp(secname(),"Cell[0].dend[149]"))<0.1){
					numOn+=1
				}else{
					numOff+=1
				}
			}
			pop_section()
		}
		onDend2.x[iii] = numOn
		
		for ii=0,curExc.size()-1{
			nsAmpa[curExc.x[ii]].start = excStart + doTbs*int( ii*tbsN/nExcAct + 0.0001)*tbsInt
			nsNmda[curExc.x[ii]].start = excStart + doTbs*int( ii*tbsN/nExcAct + 0.0001)*tbsInt
		}
		for ii=0,curInh.size()-1{
			nsVgatAt[curInh.x[ii]].start = inhStart + doTbs*int( ii*tbsN/nInhAct + 0.0001)*tbsInt
			if(totSims<1.1){	
				shapeGrOther.point_mark(synVgatAt[curInh.x[ii]],4,"O",6)
			}
		}
		
		if(totSims<1.1){ 
			graphList[0].remove(curGr-1)
			curGr = graphList[0].append(voltGrOther) 
		}
		
		run()
		
		// Assign peak voltages.
		curSeg = 0
		forall {
			for (x,0) {
				peakVoltOther[iii].x[curSeg] = vm_vmax(x)
				curSeg+=1
			}
		}
		
		// Assign specific distributions.
		soma.sec { somaVoltOther.x[iii] = vm_vmax(0.5) }
		dend1Ref.sec { dend1VoltOther.x[iii] = vm_vmax(0.5) }
		dend2Ref.sec { dend2VoltOther.x[iii] = vm_vmax(0.5) } 	
		
				
		if(totSims<1.1){ 
			graphList[0].remove(curGr-1)
		}

	
}

print "delete this later"
print "onDend2:"
onDend2.printf()
print "stats:"
print onDend2.mean(), "+-",onDend2.stdev()

// Process results.
// Subtract off baseline voltages.
for ii=0,totSims-1{
	peakVoltNone[ii].sub(baseVolts)
	peakVoltVgat[ii].sub(baseVolts)
	peakVoltOther[ii].sub(baseVolts)
}	



objref peakVoltNoneMean,peakVoltVgatMean,peakVoltOtherMean
peakVoltNoneMean = new Vector(totSegs)
peakVoltVgatMean = new Vector(totSegs)
peakVoltOtherMean = new Vector(totSegs)

for ii=0,totSims-1{
	for jj=0,totSegs-1{
		peakVoltNoneMean.x[jj] = peakVoltNoneMean.x[jj] + peakVoltNone[ii].x[jj]
		peakVoltVgatMean.x[jj] = peakVoltVgatMean.x[jj] + peakVoltVgat[ii].x[jj]
		peakVoltOtherMean.x[jj] = peakVoltOtherMean.x[jj] + peakVoltOther[ii].x[jj]
	}
}
peakVoltNoneMean.div(totSims)
peakVoltVgatMean.div(totSims)
peakVoltOtherMean.div(totSims)


somaVoltNone.sub(somaVoltBase)
dend1VoltNone.sub(dend1VoltBase)
dend2VoltNone.sub(dend2VoltBase)
somaVoltVgat.sub(somaVoltBase)
dend1VoltVgat.sub(dend1VoltBase)
dend2VoltVgat.sub(dend2VoltBase)
somaVoltOther.sub(somaVoltBase)
dend1VoltOther.sub(dend1VoltBase)
dend2VoltOther.sub(dend2VoltBase)


//////////////////////// DID REVISIONS FROM HERE

// Identify which case occurred in each simulation.
// Simulation 0: APs in all cases
// Simulation 1: APs in exc + NPY- case; no AP in NPY+ case
// Simulation 2: APs in exc; no AP in NPY- nor NPY+ case
// Simulation 3: no APs in any case

objref theAps
theAps = new Vector(totSims)

apThres=60
voltThresReport=25
// Add in results.
tot0 = 0
tot1 = 0
tot2 = 0
tot3 = 0
totOut = 0
for ii=0,totSims-1{
	if(doTuft){
			
		if(dend2VoltNone.x[ii]<voltThresReport){ // no spike in case lacking inhibition
			theAps.x[ii] = 3
			tot3 = tot3 + 1
		}else{
			if(dend2VoltVgat.x[ii]<voltThresReport){ // no spike in case with VGAT+ inhibition
				theAps.x[ii] = 2
				tot2 = tot2 + 1
			}else{
				if(dend2VoltOther.x[ii]<voltThresReport){
					theAps.x[ii] = 1
					tot1 = tot1 + 1
				}else{
					theAps.x[ii] = 0
					tot0 = tot0 + 1
				}
			}
		}
		
		// Note any cases where SST- spike occurred but not SST+ spike.
		if(dend2VoltVgat.x[ii]<voltThresReport){
			if(dend2VoltOther.x[ii]>voltThresReport){
				print "OUTLIER!"
				theAps.x[ii] = -1
				totOut = totOut + 1
			}
		}
	}else{
		
		if(somaVoltNone.x[ii]<apThres){ // no spike in case lacking inhibition
			theAps.x[ii] = 3
			tot3 = tot3 + 1
		}else{
			if(somaVoltVgat.x[ii]<apThres){ // no spike in case with VGAT+ inhibition
				theAps.x[ii] = 2
				tot2 = tot2 + 1
			}else{
				if(somaVoltOther.x[ii]<apThres){
					theAps.x[ii] = 1
					tot1 = tot1 + 1
				}else{
					theAps.x[ii] = 0
					tot0 = tot0 + 1
				}
			}
		}
		
		// Note any cases where NPY- spike occurred but not NPY+ spike.
		if(somaVoltVgat.x[ii]<apThres){
			if(somaVoltOther.x[ii]>apThres){
				print "OUTLIER!"
				theAps.x[ii] = -1
				totOut = totOut + 1
			}
		}
	}
}

print "The AP cases are: ",theAps.printf
print "To summarise:"
if(doTuft){
	print "\tThe number of dend spikes in all cases is: ",tot0
	print "\tThe number of dend spikes in pure exc. and SST- only is: ",tot1
	print "\tThe number of dend spikes in pure exc. only is: ",tot2-totOut
	print "\tThe number of subthreshold responses is: ",tot3
	print "\tThe number of outliers is: ",totOut
}else{
	print "\tThe number of APs in all cases is: ",tot0
	print "\tThe number of APs in pure exc. and NPY- only is: ",tot1
	print "\tThe number of APs in pure exc. only is: ",tot2
	print "\tThe number of subthreshold responses is: ",tot3
	print "\tThe number of outliers is: ",totOut
}
	
// Assign results to the various mod file parameters.
// 0-3: "none" simulations
// 4-7: "vgat" simulations
// 8-11: "other" simulations
// for each, go in reverse numerical order for making a given AP
// correspond to a given vmax storage location.  ie,
// 0,4,8 = APs in all cases
// 1,5,9 = AP in "none", "other"
// 2,6,10 = AP in "none"
// 3,7,11 = no APs anywhere
for ii=0,totSims-1{
	curSeg = 0
	forall {
		for(x,0){
			if( abs(theAps.x[ii]-0) < 0.1 ){
				v0_vmax(x) = v0_vmax(x) + peakVoltNone[ii].x[curSeg]/tot0
				v4_vmax(x) = v4_vmax(x) + peakVoltVgat[ii].x[curSeg]/tot0
				v8_vmax(x) = v8_vmax(x) + peakVoltOther[ii].x[curSeg]/tot0
			}
			if (abs(theAps.x[ii]-1) < 0.1 ){
				v1_vmax(x) = v1_vmax(x) + peakVoltNone[ii].x[curSeg]/tot1
				v5_vmax(x) = v5_vmax(x) + peakVoltVgat[ii].x[curSeg]/tot1
				v9_vmax(x) = v9_vmax(x) + peakVoltOther[ii].x[curSeg]/tot1
			}
			if (abs(theAps.x[ii]-2) < 0.1 ){
				v2_vmax(x) = v2_vmax(x) + peakVoltNone[ii].x[curSeg]/tot2
				v6_vmax(x) = v6_vmax(x) + peakVoltVgat[ii].x[curSeg]/tot2
				v10_vmax(x) = v10_vmax(x) + peakVoltOther[ii].x[curSeg]/tot2
			}
			if (abs(theAps.x[ii]-3) < 0.1 ){
				v3_vmax(x) = v3_vmax(x) + peakVoltNone[ii].x[curSeg]/tot3
				v7_vmax(x) = v7_vmax(x) + peakVoltVgat[ii].x[curSeg]/tot3
				v11_vmax(x) = v11_vmax(x) + peakVoltOther[ii].x[curSeg]/tot3
			}
		curSeg = curSeg + 1
		}
	}
}

// Reset some of these vmax values for representation of more interesting differences.
print "resetting some vmax values"
forall {
	for(x,0){
		v46 = v4_vmax(x) - v8_vmax(x)
		v610 = v6_vmax(x) - v10_vmax(x)
		v711 = v7_vmax(x) - v11_vmax(x)
		
		v0_vmax(x) = v46
		v2_vmax(x) = v610
		v3_vmax(x) = v711
		//v0_vmax(x) = v4_vmax(x) - v8_vmax(x)
		//v2_vmax(x) = v6_vmax(x) - v10_vmax(x)
		//v3_vmax(x) = v7_vmax(x) - v11_vmax(x)
	}
print secname(),v2_vmax(0.5),v6_vmax(0.5),v10_vmax(0.5)
}
		

// Make shape plots for output.
objref vm[12]
for ii=0,11 {
	vm[ii] = new PlotShape()
	vm[ii].exec_menu("Shape Plot")
	vm[ii].exec_menu("Show Diam")
}


vm[0].variable("v0_vmax")
vm[1].variable("v1_vmax")
vm[2].variable("v2_vmax")
vm[3].variable("v3_vmax")
vm[4].variable("v4_vmax")
vm[5].variable("v5_vmax")
vm[6].variable("v6_vmax")
