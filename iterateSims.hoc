// If doing NPY, condition dataset into AP and non-AP trials, and project
// the ensuing voltage profiles onto morphology.
objref peakVoltVgatAp,peakVoltVgatSub
objref peakVoltOtherAp,peakVoltOtherSub
objref subGr,apGr
if(!doTuft){
	if(abs(thresSwitch)<0.1){

		peakVoltVgatAp = new Vector(totSegs)
		peakVoltVgatSub = new Vector(totSegs)
		peakVoltOtherAp = new Vector(totSegs)
		peakVoltOtherSub = new Vector(totSegs)
		
		numVgatAp = 0
		numVgatSub = 0
		numOtherAp = 0
		numOtherSub = 0
		
		for ii=0,totSims-1{
			if(somaVoltVgat.x[ii]>70){
				for jj=0,totSegs-1{
					peakVoltVgatAp.x[jj] = peakVoltVgatAp.x[jj] + peakVoltVgat[ii].x[jj]
				}
				numVgatAp+=1
			}else{
				for jj=0,totSegs-1{
					peakVoltVgatSub.x[jj] = peakVoltVgatSub.x[jj] + peakVoltVgat[ii].x[jj]
				}
				numVgatSub+=1
			}
			
			if(somaVoltOther.x[ii]>70){
				for jj=0,totSegs-1{
					peakVoltOtherAp.x[jj] = peakVoltOtherAp.x[jj] + peakVoltOther[ii].x[jj]
				}
				numOtherAp+=1
			}else{
				for jj=0,totSegs-1{
					peakVoltOtherSub.x[jj] = peakVoltOtherSub.x[jj] + peakVoltOther[ii].x[jj]
				}
				numOtherSub+=1
			}
		}
		
		// Plot and compute only if have at least one trial in each class 
		// of VGAT vs. other and AP vs. sub.
		if( (numVgatAp*numVgatSub*numOtherAp*numOtherSub) >0.9 ){
			print "Number of APs in VGAT sim: ",numVgatAp
			print "Number of subthreshold responses in VGAT sim: ",numVgatSub
			print "Number of APs in other sim: ",numOtherAp
			print "Number of subthreshold responses in other sim: ",numOtherSub
		
			peakVoltVgatAp.div(numVgatAp)
			peakVoltVgatSub.div(numVgatSub)
			peakVoltOtherAp.div(numOtherAp)
			peakVoltOtherSub.div(numOtherSub)
			
			
			curSeg = 0
			forall{
				for(x,0){
					v5_vmax(x) = peakVoltVgatSub.x[curSeg] - peakVoltOtherSub.x[curSeg]
					v6_vmax(x) = peakVoltVgatAp.x[curSeg] - peakVoltOtherAp.x[curSeg]
					curSeg+=1
				}
			}
			
			subLo = 0
			subHi = 0
			apLo = 0
			apHi = 0
			
			forall {
				for(x,0) {
					if(v5_vmax(x)<subLo){subLo = v5_vmax(x)}
					if(v5_vmax(x)>subHi){subHi = v5_vmax(x)}
					if(v6_vmax(x)<apLo){apLo = v6_vmax(x)}
					if(v6_vmax(x)>apHi){apHi = v6_vmax(x)}
				}
			}
			
			subGr = new PlotShape()
			subGr.variable("v5_vmax")
			subGr.exec_menu("Shape Plot")
			subGr.exec_menu("Show Diam")
			subGr.scale(int(subLo),int(subHi+1))
			subGr.label("Sub diff")
			
			apGr = new PlotShape()
			apGr.variable("v6_vmax")
			apGr.exec_menu("Shape Plot")
			apGr.exec_menu("Show Diam")
			apGr.scale(int(apLo),int(apHi+1))
			apGr.label("AP diff")
		}
	}		
}
		


// Define upper and lower ranges for plots.
plotLo = 0
plotHi = peakVoltNoneMean.max
plotHi = int(plotHi+1) // make it a round number

// Visualise results in shape plots.
