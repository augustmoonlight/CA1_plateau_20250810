theLo = 0
theHi = 0
forall{
	for(x,0){
		if(v4_vmax(x)<theLo){
			theLo = v4_vmax(x)
		}
		if(v4_vmax(x)>theHi){
			theHi = v4_vmax(x)
		}
	}
}
if(abs(theLo)>abs(theHi)){
	theHi = abs(theLo)
	theLo = theHi*-1
}else{
	theHi = abs(theHi)
	theLo = theHi*-1
}


// Update colouring for difference plot.
nColour = 11 // total number of colours in plot; always choose odd so that middle colour is white
shDiff.colormap(nColour,1)
vm[0].colormap(nColour,1)
vm[2].colormap(nColour,1)
vm[3].colormap(nColour,1)
for (ijk=0; ijk<(nColour-0.01); ijk=ijk+1){
	// Assign scale factor.
	curCol = ( ijk-(nColour-1)/2 ) // centre value about 0
	curCol = curCol / ( (nColour-1)/2 ) // value range is now [-1,1]; adjusted again below
	if(curCol<(-0.001)){
		theSign = -1
	}else{
		theSign = 1
	}
	curCol = int(abs(curCol)*255+0.1) // value range is now [0,255] for pixel intensity
	
	if(theSign<0){
		shDiff.colormap(ijk,int(255.1-curCol),int(255.1-curCol),255) // GIVES BLUE
		vm[0].colormap(ijk,int(255.1-curCol),int(255.1-curCol),255) // GIVES BLUE
		vm[2].colormap(ijk,int(255.1-curCol),int(255.1-curCol),255) // GIVES BLUE
		vm[3].colormap(ijk,int(255.1-curCol),int(255.1-curCol),255) // GIVES BLUE
		//shDiff.colormap(ijk,int(255.1-curCol),255,255) // GIVES CYAN
	}else{
		//shDiff.colormap(ijk,255,255,int(255.1-curCol)) // GIVES YELLOW
		shDiff.colormap(ijk,255,int(255.1-curCol),int(255.1-curCol)) // GIVES RED
		vm[0].colormap(ijk,255,int(255.1-curCol),int(255.1-curCol)) // GIVES RED
		vm[2].colormap(ijk,255,int(255.1-curCol),int(255.1-curCol)) // GIVES RED
		vm[3].colormap(ijk,255,int(255.1-curCol),int(255.1-curCol)) // GIVES RED
	}
}

shDiff.scale(theLo,theHi)
shDiff.label("difference")


// Visualise results in scatter plots.
objref scatNone,scatVgat,scatOther

scatNone = new Graph()
peakVoltNoneMean.mark(scatNone,segDist,"O",3)
scatNone.size(-200,500,plotLo,plotHi)
scatNone.label("No inhib, avg vmax")

scatVgat = new Graph()
peakVoltVgatMean.mark(scatVgat,segDist,"O",3)
scatVgat.size(-200,500,plotLo,plotHi)
scatVgat.label("VGAT, avg vmax")

scatOther = new Graph()
