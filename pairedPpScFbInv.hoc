// This does paired PP-SC inputs with feedback from the tuft.

// Create graph.
objref ppScFbInvGr
strdef lab1,lab2
lab1 = "I PP + SC + FB"
lab2 = "Inh + exc + FB"
toRem = addTracesToGraph(ppScFbInvGr,lab1,lab2)

// Prep synapses.
excInhPrep(nExcUseTuft,nExcUseCa3,nInhFf,nInhCa3,nInhFb,1)

// Run
run()

// Prep for next run.
graphList[0].remove(toRem-1)

