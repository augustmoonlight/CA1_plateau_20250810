// This does paired PP-SC inputs with feedback from the tuft.

// Create graph.
objref ppScFbGr
strdef lab1,lab2
lab1 = "PP + SC + FB"
lab2 = "Inh + exc + FB"
toRem = addTracesToGraph(ppScFbGr,lab1,lab2)

// Prep synapses.
excInhPrep(nExcUseTuft,nExcUseCa3,nInhFf,nInhCa3,nInhFb)

// Run
run()

// Prep for next run.
graphList[0].remove(toRem-1)

