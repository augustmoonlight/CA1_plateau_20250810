// This does a PP + SC stimulus with inverted inputs.

// Create graph.
objref ppScInvGr
strdef lab1,lab2
lab1 = "I PP + SC"
lab2 = "Inh + exc"
toRem = addTracesToGraph(ppScInvGr,lab1,lab2)

// Prep synapses.
excInhPrep(nExcUseTuft,nExcUseCa3,nInhFf,nInhCa3,0,1)

// Run
run()

// Prep for next run.
graphList[0].remove(toRem-1)

